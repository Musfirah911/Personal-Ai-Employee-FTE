# AI Employee — Gold Tier Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# SETUP: Copy this file to .env and fill in your values.
#        NEVER commit .env to git. It is already in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── Safety ────────────────────────────────────────────────────────────────────
# Set to "true" during development to prevent all real external actions.
# All watchers, skills, and the orchestrator respect this flag.
DRY_RUN=true

# ── Gmail API ─────────────────────────────────────────────────────────────────
# From: console.cloud.google.com → Your Project → OAuth 2.0 Credentials (Desktop App)
# No credentials.json or token.json files needed — auth is env-var driven only.
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# One-time setup: run `python watchers/gmail_watcher.py --get-token`
# Copy the printed refresh token here. Leave blank to run in partial auth mode.
GMAIL_REFRESH_TOKEN=

# Poll interval for Gmail watcher in seconds (default: 120 = 2 minutes)
GMAIL_INTERVAL=120

# ── LinkedIn ───────────────────────────────────────────────────────────────────
# Playwright login (used by linkedin_poster.py for browser automation)
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password
LINKEDIN_HEADLESS=false

# API token (used by linkedin_watcher.py to post via LinkedIn UGC API)
# From: linkedin.com/developers → Your App → Auth → OAuth 2.0 tokens
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID_HERE

# ── MCP Servers ───────────────────────────────────────────────────────────────
# Absolute path to the email MCP server entry point
EMAIL_MCP_PATH=/absolute/path/to/email-mcp/index.js

# Browser MCP (for web automation — future use)
BROWSER_MCP_HEADLESS=true

# ── Scheduler ─────────────────────────────────────────────────────────────────
# 24-hour format, local time
DAILY_BRIEFING_HOUR=8
WEEKLY_BRIEFING_HOUR=7

# Day of week for CEO briefing (monday, tuesday, etc.)
WEEKLY_BRIEFING_DAY=monday

# ── Facebook + Instagram (Meta) ───────────────────────────────────────────────
# Single Meta account login covers both Facebook and Instagram
FACEBOOK_EMAIL=your_facebook_email@example.com
FACEBOOK_PASSWORD=your_facebook_password
# Set false to see the browser window (recommended first run)
FACEBOOK_HEADLESS=false

# ── Twitter/X ─────────────────────────────────────────────────────────────────
# Login credentials for X.com (used by Playwright — no API key needed)
TWITTER_EMAIL=your_twitter_email@example.com
TWITTER_PASSWORD=your_twitter_password
# Optional: your @username — needed if X asks for username confirmation on login
TWITTER_USERNAME=your_twitter_username
# Set false to see the browser window (recommended first run)
TWITTER_HEADLESS=false

# ── ERPNext (Accounting MCP) ──────────────────────────────────────────────────
# Absolute path to the ERP_Next-MCP folder
ERPNEXT_MCP_PATH=/absolute/path/to/ERP_Next-MCP

# Your ERPNext instance URL (local Docker or cloud)
ERPNEXT_URL=http://localhost:8080

# Option 1: Username/password (takes priority)
ERPNEXT_USERNAME=
ERPNEXT_PASSWORD=

# Option 2: API key/secret (fallback)
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# Poll interval for ERPNext watcher in seconds (default: 900 = 15 min)
ERPNEXT_INTERVAL=900

# ── Playwright (shared by all social media posters) ───────────────────────────
# Optional: override Chrome path if not in the default location
# Default: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_PATH=

# ── Rate Limits ───────────────────────────────────────────────────────────────
# Safety caps to prevent runaway automation
MAX_EMAILS_PER_HOUR=10
MAX_POSTS_PER_DAY=3
MAX_PAYMENTS_PER_DAY=5
