# ERPNext MCP Server - Environment Variables
# Copy this file to .env and fill in your credentials.
# Priority: username+password (session auth) is used first.
# If not set, falls back to api_key+api_secret (token auth).

ERPNEXT_URL=https://your-erpnext-instance.com

# Option 1: Username/Password (session auth) — takes priority
ERPNEXT_USERNAME=
ERPNEXT_PASSWORD=

# Option 2: API Key/Secret (token auth) — fallback
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# Optional
ERPNEXT_TIMEOUT=30
