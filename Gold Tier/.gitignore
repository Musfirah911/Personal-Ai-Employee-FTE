# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env
!.env.example

# ── OAuth / API credentials ───────────────────────────────────────────────────
client_secret*.json
service_account*.json

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/

# ── Browser / Chrome profile data ────────────────────────────────────────────
**/chrome_profile/
**/.meta_profile/
**/.twitter_profile/
**/.linkedin_profile/
AI_Employee_Vault/Logs/.twitter_cookies.json

# ── Python virtual environments ───────────────────────────────────────────────
.venv/
venv/

# ── Log files (may contain email/message content) ────────────────────────────
AI_Employee_Vault/Logs/*.jsonl
AI_Employee_Vault/Logs/*.png

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Runtime state (generated by watchers) ────────────────────────────────────
AI_Employee_Vault/Logs/.gmail_processed_ids.txt
AI_Employee_Vault/Logs/.scheduler_state.json

# ── Personal data — real emails, replies, names (never publish) ──────────────
AI_Employee_Vault/**/EMAIL_*.md
AI_Employee_Vault/**/REPLY_*.md
AI_Employee_Vault/**/FLAG_*.md

# ── Credential files (safety net — these should never be created) ─────────────
token.json
credentials.json
*.token
*.pkl

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
